<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans 
        http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
    <bean class = "in.vj.beans.Student" id = "student">
    	<property name = "name" value = "Vishal"></property>
    </bean>
    
    <bean class = "in.vj.beans.Employee" id = "emp">
    	<property name = "name" value = "Sanjay"></property>
    	<property name="phno" value="6548241640"></property>
    </bean>
    
    <bean class = "in.vj.processor.PostProcessor" />

</beans>