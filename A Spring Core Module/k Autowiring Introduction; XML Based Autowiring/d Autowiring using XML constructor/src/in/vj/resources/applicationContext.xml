<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
    
   
   <bean class = "in.vj.beans.Address" id = "address">
   	
   		<constructor-arg  value="186" />
   		<constructor-arg  value="Delhi" />
   		<constructor-arg  value="965487" /> 
   </bean>
   
   
    <bean class = "in.vj.beans.Student" id = "stdId" autowire = "constructor">
   	
   		<constructor-arg value= "Vijay" index = "0"/>
   		<constructor-arg value = "65" index ="1" />

   </bean>

</beans>