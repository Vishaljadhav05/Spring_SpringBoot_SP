<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE beans PUBLIC "-//SPRING//DTD BEAN 2.0//EN"
        "http://www.springframework.org/dtd/spring-beans-2.0.dtd">

<beans>

<!-- Target Bean -->
	<bean class="in.vj.services.BankTransactions" id = "bankTransId"  />
	
	<bean class="in.vj.aspects.LoggingAspects" id = "LogAspectId"  />
	
	<bean class = "org.springframework.aop.framework.ProxyFactoryBean" id = "proxyId" >
	
		<property name="target" ref = "bankTransId" />
		<property name="InterceptorNames">
			<list>
				<value>LogAspectId</value>
			</list>
		
		</property>
	
	</bean>


</beans>