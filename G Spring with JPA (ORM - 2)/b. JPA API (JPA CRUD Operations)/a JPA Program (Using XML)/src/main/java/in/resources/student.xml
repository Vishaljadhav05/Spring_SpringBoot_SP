<!DOCTYPE hibernate-mapping PUBLIC 
    "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
    "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
    
<hibernate-mapping>
	<class name="in.entity.Student" table = "std_marks">
		<id name= "id" column="std_id"/>
		<property name="name" column="std_name"></property>
		<property name="email" column="std_email"></property>
		<property name="marks" column="std_marks"></property>
	
	</class> 
</hibernate-mapping>