<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
    
    <!-- bean definitions using id & name -->
    
    <bean class = "com.sp.beans.Student" id = "stdObj1">
    
    	<property name="name" value = "Prafull Jadhav"></property>
    	<property name="rollNo" value = "201"></property>
    </bean>
    
     <bean class = "com.sp.beans.Student" name = "stdObj2">
    
    	<property name="name" value = "Vishal Jadhav"></property>
    	<property name="rollNo" value = "308"></property>
    </bean>

</beans>